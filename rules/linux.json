  {
    "id": "LNX-FTP-PASS",
    "comment": "4th token must not start with - or / (flags/options) and must not be a bare number (port), preventing 'ftp -n host 21' from redacting the port.",
    "phrase": [
      "ftp",
      "<any>",
      "<any>",
      "<redact:^[^-/][^0-9].*|^[^-/0-9].+>"
    ],
    "priority": 2,
    "enabled": true,
    "min_length": 4
  },
  {
    "id": "LNX-OPENSSL-PASS",
    "comment": "pass:secret is a single token. '<redact:^pass:.+>' matches it; redact_after trims the 'pass:' prefix so only the secret is starred.",
    "phrase": ["-passin", "<redact:^pass:.+>"],
    "redact_after": "pass:",
    "priority": 1,
    "enabled": true,
    "min_length": 5
  },
  {
    "id": "LNX-OPENSSL-PASSOUT",
    "comment": "Same as LNX-OPENSSL-PASS but for -passout.",
